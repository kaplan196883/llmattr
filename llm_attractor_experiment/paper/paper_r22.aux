\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Fig 2. \textbf  {Dense O1 adversarial ED50 fit.} O1 append-mode adversarial dose response from the dense confirmatory rerun, with 8 doses x $n=200$ per cell. Black points are observed switching rates with family-cluster bootstrap 95\% CIs; the blue curve is a 4-parameter logistic fit (\texttt  {a=0.69, d=0.28, b=1.16, ED50=36 tok}); the dashed red line marks the bootstrap-median ED50 = 52 tokens [CI 8.5, 242]. Source: \texttt  {data/exp\_perturb\_O1\_ed50\_dense/reports/perturbation/ed50\_curve.png}.}}{26}{figure.caption.25}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Fig 4. \textbf  {Post-perturbation relaxation and recovery.} Relaxation curves after perturbation show that many trajectories move transiently but do not remain in the injected post-jump basin. The curves support the distinction between raw switching and durable escape. Source: \texttt  {data/aggregated/perturbation\_cross\_regime/cross\_relaxation\_curves.png}.}}{27}{figure.caption.26}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Fig 3. \textbf  {Persistent escape under cluster granularity.} Persistent-escape rates recomputed under K-means $k=12$, K-means $k=4$, and HDBSCAN. No clustering convention reaches the 50\% persistent-escape threshold up to 400 injected tokens. Source: \texttt  {data/aggregated/multi\_granularity\_persistence.png}.}}{27}{figure.caption.28}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Figure K. \textbf  {Dense-dose ED50 fit.} O1 adversarial dose-response from the confirmatory rerun, with 8 doses × $n=200$ per cell and one control cell. Black points are observed switching rates with family-cluster-bootstrap 95\% CIs; the blue curve is a 4-parameter logistic fit (\texttt  {a=0.69, d=0.28, b=1.16, ED50=36 tok}); the dashed red line marks the bootstrap-median ED50 = 52 tokens [CI 8.5, 242]. Source: \texttt  {data/exp\_perturb\_O1\_ed50\_dense/reports/perturbation/ed50\_curve.png}.}}{28}{figure.caption.29}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Replace-mode fragility is primarily a memory-policy effect}{28}{subsection.5.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Publication-scale runs preserve regime ordering}{29}{subsection.5.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Fig 6. \textbf  {Leakage-aware basin predictability.} Group-aware basin-predictability with prompt families held out across folds. O1 remains the strongest leakage-free predictability result, while O2, O3, and D1 drop substantially under family-held-out validation. Source: \texttt  {data/aggregated/group\_aware\_basin\_pred.png}.}}{30}{figure.caption.36}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Perturbation pilots separate append from replace}{30}{subsection.5.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Fig 7. \textbf  {Cross-experiment dynamics map.} Regime-level map in late-window $\lambda _1$ versus sharpness-dimension space, showing broad separation of replace, append, and dialog regimes. The plot is diagnostic rather than endpoint-defining. Source: \texttt  {data/aggregated/dynamics\_plots/regime\_map\_rolling\_k3.png}.}}{31}{figure.caption.37}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.5}Drill-down dialog adds content gravity}{31}{subsection.5.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Injection timing reveals basin hardening}{31}{subsection.5.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Fig 5. \textbf  {Cross-regime perturbation switching.} Final-cluster switching rates across append, replace, and dialog perturbation pilots. Replace-mode O2/O3 saturation should be read as overwrite-protocol sensitivity, not as a clean injected-token barrier. Source: \texttt  {data/aggregated/perturbation\_cross\_regime/cross\_switching\_rates.png}.}}{32}{figure.caption.39}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.7}Cluster stability and multi-granularity switching}{32}{subsection.5.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Fig 8. \textbf  {Basin hardening by injection time.} Switching rates for early, middle, and late injections in O1 and D1, with $n=50$ per cell and 95\% Wilson confidence intervals. D1 shows partial late hardening, whereas O1 adversarial append perturbations remain approximately flat across injection time. Source: \texttt  {data/aggregated/perturbation\_basin\_hardening/basin\_hardening.png}.}}{33}{figure.caption.41}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Fig 9. \textbf  {Switching under alternative basin granularities.} Perturbation switching recomputed under K-means $k=12$, K-means $k=4$, and HDBSCAN. The O1 adversarial-versus-OOD contrast is robust across granularities, while D1 is more granularity-sensitive. Source: \texttt  {data/aggregated/multi\_granularity\_switching.png}.}}{34}{figure.caption.45}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.8}Per-cluster semantic inspection}{34}{subsection.5.8}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.9}Per-family heterogeneity}{34}{subsection.5.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Fig 10. \textbf  {Per-family O1 adversarial dose response.} Family-level sparse O1 adversarial dose curves with $n=10$ trajectories per family-dose cell. Heterogeneity behind the population-level ED50 explains the wide family-cluster bootstrap interval. Source: \texttt  {data/aggregated/per\_family\_ed50.png}.}}{35}{figure.caption.48}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.10}Embedding-space invariance}{35}{subsection.5.10}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Fig 11. \textbf  {Embedding-model ablation.} Diagnostics recomputed under \texttt  {text-embedding-3-small}, \texttt  {text-embedding-3-large}, and \texttt  {all-mpnet-base-v2}. Basin predictability and coarse recurrence ordering are more stable than sharpness dimension. Source: \texttt  {data/aggregated/embedding\_ablation/comparison.png}.}}{36}{figure.caption.51}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.11}Cross-model thesis verification}{36}{subsection.5.11}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.12}Density landscapes are descriptive, not calibrated}{37}{subsection.5.12}\protected@file@percent }
