\@writefile{lof}{\contentsline {figure}{\numberline {23}{\ignorespaces ED Fig 7. \textbf  {Basin-predictability grid.} Per-experiment basin-predictability panels showing how predictability varies across regimes and observables. Source: \texttt  {data/aggregated/basin\_predictability\_cross/cross\_basin\_predictability\_grid.png}.}}{59}{figure.caption.81}\protected@file@percent }
