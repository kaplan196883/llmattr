# ============================================================================
# SECRETS — must never leak
# ============================================================================
.env
.env.local
*.pem
*.key

# ============================================================================
# Python
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/
.tox/

# ============================================================================
# OS / editors
# ============================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ============================================================================
# Experiment run logs (large, recreatable, not part of scientific record)
# ============================================================================
llm_attractor_experiment/data/op_logs/
llm_attractor_experiment/data/run*.out
llm_attractor_experiment/data/*.log

# ============================================================================
# Experiment artifacts — DO NOT track in git. Released to Zenodo at paper
# acceptance (see §9 of ARTICLE.md). Local tree may exceed 30 GB; pushing
# any of this through plain git or LFS will exceed quotas/timeouts.
# History was stripped on 2026-05-05 via git filter-repo --invert-paths
# --path llm_attractor_experiment/data; do not undo that by re-tracking.
# ============================================================================
llm_attractor_experiment/data/exp_*/
llm_attractor_experiment/data/aggregated/
llm_attractor_experiment/data/pub_dynamics_plots/
llm_attractor_experiment/data/dynamics_cross_experiment.csv
llm_attractor_experiment/data/dynamics_plots/
llm_attractor_experiment/data/cross_model_logs/

# Older derived-artifact patterns (kept as belt-and-suspenders for any
# experiment dir that escapes the broader exp_*/ rule above)
llm_attractor_experiment/data/**/embeddings/**/*.npy
llm_attractor_experiment/data/**/embeddings/**/*.parquet
llm_attractor_experiment/data/**/*.mp4
llm_attractor_experiment/data/**/*.gif

# Third-party PDFs (papers, references)
*.pdf

# Local Claude/agent state
.claude/

# Junk drawer (historical planning briefs, third-party PDFs, etc.)
junk/

# Empty placeholder subdirs at data/ root (experiments live under data/exp_*)
llm_attractor_experiment/data/reports/
llm_attractor_experiment/data/raw/
llm_attractor_experiment/data/metrics/
llm_attractor_experiment/data/embeddings/
