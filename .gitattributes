# Raw step trajectories (jsonl, can be very large)
llm_attractor_experiment/data/**/raw/steps.jsonl filter=lfs diff=lfs merge=lfs -text

# Cross-model run logs (some 40-50 MB each)
llm_attractor_experiment/data/aggregated/cross_model_logs/*.log filter=lfs diff=lfs merge=lfs -text

# Submission archives
llm_attractor_experiment/paper/*.zip filter=lfs diff=lfs merge=lfs -text
llm_attractor_experiment/paper/*.tar.gz filter=lfs diff=lfs merge=lfs -text

# Compiled paper PDF (regen-able but kept tracked for releases)
llm_attractor_experiment/paper/paper.pdf filter=lfs diff=lfs merge=lfs -text

# Generated parquet artefacts (when present alongside non-ignored data)
llm_attractor_experiment/data/**/*.parquet filter=lfs diff=lfs merge=lfs -text

# Large aggregate plots (sized PNGs above ~1 MB show up here; pattern catches all)
llm_attractor_experiment/data/aggregated/**/*.png filter=lfs diff=lfs merge=lfs -text
